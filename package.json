{
	"name": "sels",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"resetdb": "mariadb -u root -p -e 'DROP DATABASE IF EXISTS sels' && npx prisma db push",
		"genprisma": "npx prisma db pull && npx prisma generate",
		"dbpush": "echo 'SET FOREIGN_KEY_CHECKS = 0;\n' > sels.sql && mariadb-dump --no-create-info --compact -u root -p sels >> sels.sql && echo '\nSET FOREIGN_KEY_CHECKS = 1;\n' >> sels.sql",
		"dbpull": "npm run resetdb && mariadb -u root -p sels < sels.sql && npm run genprisma",
		"dev": "vite dev",
		"build": "prisma generate && prisma db push && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@fontsource-variable/figtree": "^5.2.10",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.3.0",
		"@types/eslint": "^9.6.0",
		"@types/node": "^25.9.0",
		"clsx": "^2.1.1",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"globals": "^15.0.0",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"prisma": "^5.21.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^8.0.13"
	},
	"dependencies": {
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@prisma/client": "^5.21.1",
		"@types/random-name": "^0.1.2",
		"argon2": "^0.41.1",
		"bits-ui": "^2.18.1",
		"formsnap": "^2.0.1",
		"paneforge": "^1.0.0-next.6",
		"random-name": "^0.1.2",
		"svelte-sonner": "^1.1.1",
		"vaul-svelte": "^1.0.0-next.7"
	},
	"overrides": {
		"cookie": "^0.7.0"
	}
}
