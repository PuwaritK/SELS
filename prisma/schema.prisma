generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model account {
  user_id     Int       @id @default(autoincrement())
  role_id     Int       @default(1)
  username    String    @unique(map: "username") @db.VarChar(20)
  password    String    @db.VarChar(256)
  paradise_id Int?
  currency    Int       @default(27000)
  last_feed   DateTime  @default(dbgenerated("(NOW() - interval '1 day')")) @db.Timestamp(0)
  last_play   DateTime  @default(dbgenerated("(NOW() - interval '1 day')")) @db.Timestamp(0)
  last_show   DateTime  @default(dbgenerated("(NOW() - interval '1 day')")) @db.Timestamp(0)
  role        role      @relation(fields: [role_id], references: [role_id], onUpdate: Restrict)
  paradise    paradise? @relation(fields: [paradise_id], references: [paradise_id])
  session     session[]
  orders      order[]

  @@index([paradise_id])
  @@index([role_id])
}

model order {
  order_id       String   @id @default(uuid())
  user_id        Int
  amount_spc     Int
  price_fiat     Float
  currency_code  String   @default("USD")
  payment_method String
  status         String   @default("PENDING")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  account        account  @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
}

model gacha {
  gacha_id    Int      @id @default(autoincrement())
  paradise_id Int
  name        String   @db.VarChar(25)
  tier_id     Int
  paradise    paradise @relation(fields: [paradise_id], references: [paradise_id], onUpdate: Restrict)
  tier        tier     @relation(fields: [tier_id], references: [tier_id], onUpdate: Restrict)

  @@index([paradise_id])
  @@index([tier_id])
}

model paradise {
  paradise_id Int       @id @default(autoincrement())
  name        String    @unique(map: "name") @db.VarChar(30)
  rating      Int?
  account     account[]
  gacha       gacha[]
  sel         sel[]
}

model role {
  role_id Int       @id @default(autoincrement())
  name    String?   @db.VarChar(20)
  url     String?   @db.VarChar(50)
  account account[]
}

model sel {
  sel_id      Int       @id @default(autoincrement())
  name        String?   @db.VarChar(75)
  type_id     Int
  colour      String    @db.VarChar(25)
  sex_id      Int
  dob         DateTime  @db.Timestamp(0)
  weight      Int
  show_xp     Int       @default(0)
  price       Int
  tier_id     Int
  paradise_id Int?
  type        type      @relation(fields: [type_id], references: [type_id], onUpdate: Restrict)
  sex         sex       @relation(fields: [sex_id], references: [sex_id], onUpdate: Restrict)
  tier        tier      @relation(fields: [tier_id], references: [tier_id], onUpdate: Restrict)
  paradise    paradise? @relation(fields: [paradise_id], references: [paradise_id], onDelete: Cascade)

  @@index([paradise_id])
  @@index([sex_id])
  @@index([tier_id])
  @@index([type_id])
}

model sex {
  sex_id Int    @id @default(autoincrement())
  name   String @db.VarChar(20)
  sel    sel[]
}

model tier {
  tier_id Int     @id @default(autoincrement())
  name    String  @db.VarChar(15)
  gacha   gacha[]
  sel     sel[]
}

model type {
  type_id   Int     @id @default(autoincrement())
  type_name String? @db.VarChar(25)
  sel       sel[]
}

model session {
  id        String   @id
  userId    Int
  expiresAt DateTime
  account   account  @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@index([userId])
}
